// Jastram Engineering – Project Management Tool
// Prisma schema for PostgreSQL

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum ProjectStatus {
  NOT_STARTED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum MilestoneType {
  KICK_OFF  // Engineering Kick-Off Meeting
  PDR       // Preliminary Design Review
  FDR       // Final Design Review
}

enum MilestoneStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum DeliverableType {
  LONG_LEAD            // Long lead info to purchasing
  PICKLIST             // Scope of supply / picklist to production
  PROD_RELEASE         // Production info release (custom parts: drawings, BOM)
  SYS_DESIGN_CUSTOMER  // System design drawing released to customer
  CLASS_SUBMIT         // Submit drawings/calculations to class society
  FAT                  // Class society inspection/test (FAT)
  MANUAL               // System manual completion
  SHIPPING             // Shipping date — kept in sync with Project.plannedDeliveryDate
}

enum DeliverableStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  COMPLETED
  ON_HOLD
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum UserRole {
  VIEWER  // Read-only on all resources
  EDITOR  // View + create + edit; no delete or settings
  ADMIN   // Full access including delete and settings
}

// ─────────────────────────────────────────────
// Department
// ─────────────────────────────────────────────

model Department {
  id        String   @id @default(cuid())
  name      String   @unique   // e.g. "Engineering" | "Purchasing" | "Production"
  users     User[]

  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────
// User — linked to Supabase Auth via authId
// ─────────────────────────────────────────────

model User {
  id           String        @id @default(cuid())
  authId       String        @unique   // Supabase auth uid (auth.users.id)
  email        String        @unique
  name         String?

  departmentId String?
  department   Department?   @relation(fields: [departmentId], references: [id])

  role         UserRole      @default(VIEWER)

  notifications Notification[]
  assignedIssues Issue[]     @relation("IssueAssignee")

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

// ─────────────────────────────────────────────
// Project
// ─────────────────────────────────────────────

model Project {
  id                  String               @id @default(cuid())
  projectNumber       String               @unique
  clientName          String
  shipType            String
  classSociety        String
  projectManagerName  String
  plannedDeliveryDate DateTime?            // kept in sync with SHIPPING deliverable dueDate
  status              ProjectStatus        @default(NOT_STARTED)
  description         String?
  generalNotes        String?              // e.g. on hold, waiting for info, blockers
  hullNumbers         String[]             @default([])  // one or multiple hulls (optional)
  // Sales order numbers: one project (JQ + 6 digits) can have multiple → SalesOrder[]

  milestones          Milestone[]
  deliverables        ProjectDeliverable[]
  tasks               Task[]
  salesOrders         SalesOrder[]
  issues              Issue[]

  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

// ─────────────────────────────────────────────
// SalesOrder — multiple per project
// Same steering system sold to multiple ships; each sale = one SalesOrder.
// ─────────────────────────────────────────────

model SalesOrder {
  id               String   @id @default(cuid())
  projectId        String
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  salesOrderNumber String
  shippingDate     DateTime?   // optional per-order shipping date override

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([projectId, salesOrderNumber])
}

// ─────────────────────────────────────────────
// Milestone (the 3 engineering review meetings)
// Auto-created (KICK_OFF, PDR, FDR) when a project is created.
// Placement relative to deliverables is fluid per project.
// ─────────────────────────────────────────────

model Milestone {
  id        String          @id @default(cuid())
  projectId String
  project   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  type      MilestoneType
  dueDate   DateTime?
  status    MilestoneStatus @default(SCHEDULED)
  notes     String?         // project-specific notes

  reminders ReminderLog[]

  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([projectId, type])
}

// ─────────────────────────────────────────────
// ProjectDeliverable (the 8 standard tracking steps)
// Auto-created for each project on creation.
// SHIPPING dueDate is kept in sync with Project.plannedDeliveryDate.
// ─────────────────────────────────────────────

model ProjectDeliverable {
  id        String            @id @default(cuid())
  projectId String
  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)

  type      DeliverableType
  dueDate   DateTime?
  status    DeliverableStatus @default(NOT_STARTED)
  notes     String?
  // Manual-printing fields (used when type = MANUAL)
  copiesToPrint   Int?     // number of manual copies to print
  readyForPrinting Boolean? @default(false) // manual already ready for printing

  reminders ReminderLog[]

  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([projectId, type])
}

// ─────────────────────────────────────────────
// Task (Kanban cards within a project)
// ─────────────────────────────────────────────

model Task {
  id             String           @id @default(cuid())
  projectId      String
  project        Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title          String
  description    String?
  status         TaskStatus       @default(TODO)
  orderIndex     Int              @default(0)   // position within Kanban column
  dueAt          DateTime?
  estimatedHours Decimal?         @db.Decimal(6, 2)
  specJson       String?          // imperial unit specs: {"torque_lb_ft": 120, "length_in": 24}

  assignments    TaskAssignment[]

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

// ─────────────────────────────────────────────
// TeamMember
// ─────────────────────────────────────────────

model TeamMember {
  id                   String           @id @default(cuid())
  name                 String
  capacityHoursPerWeek Decimal          @default(40) @db.Decimal(5, 2)

  assignments          TaskAssignment[]

  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
}

// ─────────────────────────────────────────────
// TaskAssignment — links tasks to team members
// ─────────────────────────────────────────────

model TaskAssignment {
  id             String     @id @default(cuid())
  taskId         String
  task           Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  teamMemberId   String
  teamMember     TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)

  allocatedHours Decimal?   @db.Decimal(6, 2)

  createdAt      DateTime   @default(now())

  @@unique([taskId, teamMemberId])
}

// ─────────────────────────────────────────────
// Notification — in-app alerts (bell icon)
// userId is nullable: null = system-wide; set = scoped to that user (once auth added)
// ─────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  type      String   // e.g. "deadline_reminder"
  title     String
  body      String
  link      String?  // URL to navigate to on click
  read      Boolean  @default(false)

  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────
// ReminderLog — prevents duplicate email/in-app sends
// Either milestoneId or projectDeliverableId is set (not both).
// ─────────────────────────────────────────────

model ReminderLog {
  id                   String              @id @default(cuid())
  milestoneId          String?
  milestone            Milestone?          @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  projectDeliverableId String?
  projectDeliverable   ProjectDeliverable? @relation(fields: [projectDeliverableId], references: [id], onDelete: Cascade)

  reminderWindow       String              // e.g. "7d", "1d", "0d"
  channel              String              // "email" | "in_app"

  sentAt               DateTime            @default(now())

  @@unique([milestoneId, reminderWindow, channel])
  @@unique([projectDeliverableId, reminderWindow, channel])
}

// ─────────────────────────────────────────────
// Issue — project issue log
// ─────────────────────────────────────────────

model Issue {
  id          String       @id @default(cuid())
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  assigneeId  String?
  assignee    User?        @relation("IssueAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  title       String
  description String?
  dueDate     DateTime?
  status      IssueStatus  @default(OPEN)

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([projectId])
  @@index([assigneeId])
}
